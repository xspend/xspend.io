# Copy this file to .env and fill in real values. NEVER commit .env.
JWT_SECRET_KEY=generate-a-long-random-string-here
DATABASE_URL=sqlite:///./financeai.db
ENVIRONMENT=development
ANTHROPIC_API_KEY=your-anthropic-key-here-optional

# Where verification links point (a frontend route). Falls back to the first
# FRONTEND_ORIGINS entry, then http://localhost:5173, if unset.
APP_BASE_URL=http://localhost:5173

# SMTP for transactional email (signup verification). If any of these are
# unset, the app logs the verification link to stdout instead of sending —
# that's the default for local dev, so signup works with zero email setup.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=xspend
SMTP_STARTTLS=true
SMTP_SSL=false

# Auth token/OTP timing — all optional, these are the defaults.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=60
OTP_EXPIRE_MINUTES=2
MAX_OTP_ATTEMPTS=5
OTP_LOCKOUT_MINUTES=10
